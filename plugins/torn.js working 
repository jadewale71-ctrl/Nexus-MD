            // Subtract debt from net worth calculation
            nw -= (p.debt || 0);

            richList.push({ id: p._id, username: p.username, nw: nw, money: p.money, propDetails, cryptoDetails });
        }
        
        richList.sort((a,b) => b.nw - a.nw);
        const top = richList.slice(0, 10);
        
        let txt = `🏆 *FORBES RICHEST PLAYERS* 🏆\n_(Ranked by Total Net Worth)_\n\n`;
