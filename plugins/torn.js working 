cmd({ pattern: 'emergencytax', desc: '[Creator] Apply one-time emergency tax to drain extreme balances', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from }) => {
    try {
        const pId = await getPlayerId(conn, sender);
        if (pId !== '2348084644182') return conn.sendMessage(from, { text: `❌ Creator only.` }, { quoted: mek });

        // Emergency tax brackets — applied once to total (wallet + bank)
        // These are deliberately savage for extreme balances
        const EMERGENCY_BRACKETS = [
            { threshold: 1_000_000_000_000_000, rate: 0.9999 }, // $1 quadrillion+ → 99.99%
            { threshold: 1_000_000_000_000,     rate: 0.9990 }, // $1 trillion+    → 99.9%
            { threshold: 100_000_000_000,        rate: 0.990  }, // $100 billion+   → 99%
            { threshold: 10_000_000_000,         rate: 0.950  }, // $10 billion+    → 95%
            { threshold: 1_000_000_000,          rate: 0.850  }, // $1 billion+     → 85%
            { threshold: 100_000_000,            rate: 0.600  }, // $100 million+   → 60%
            { threshold: 10_000_000,             rate: 0.350  }, // $10 million+    → 35%
            { threshold: 1_000_000,              rate: 0.150  }, // $1 million+     → 15%
        ];

        function calcEmergencyTax(total) {
            for (const b of EMERGENCY_BRACKETS) {
                if (total >= b.threshold) return Math.floor(total * b.rate);
            }
            return 0; // under $1M — untouched
        }

        await conn.sendMessage(from, { text: `⚡ *EMERGENCY TAX NOTICE*\nScanning all accounts...\nSmall players ($1M under) are untouched.` }, { quoted: mek });

        const players = await Player.find({}).exec();
        let affected = 0, totalSeized = 0;

        for (const p of players) {
            const total = (p.money || 0) + (p.bank || 0);
            const taxAmt = calcEmergencyTax(total);
            if (taxAmt <= 0) continue;

            // Drain from wallet first, then bank
            const fromWallet = Math.min(p.money || 0, taxAmt);
            p.money = Math.max(0, (p.money || 0) - fromWallet);
            const remaining  = taxAmt - fromWallet;
            if (remaining > 0) p.bank = Math.max(0, (p.bank || 0) - remaining);

            const rate = EMERGENCY_BRACKETS.find(b => total >= b.threshold)?.rate || 0;
            logAction(p, `💀 Emergency tax — ${(rate*100).toFixed(2)}% seized on ${fmtMoney(total)} balance`);
            await p.save();
            affected++;
            totalSeized += taxAmt;
        }

        logGlobal('💀', `*EMERGENCY TAX* — Creator seized ${fmtMoney(totalSeized)} from ${affected} players.`);
        return conn.sendMessage(from, {
            text: [
                `💀 *EMERGENCY TAX COMPLETE*`, ``,
                `👥 Players taxed: *${affected}* of ${players.length}`,
                `💸 Total seized: *${fmtMoney(totalSeized)}*`,
