cmd({ pattern: 'school', desc: 'School — enroll, study, take exams, view degrees', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
    try {
        const pId = await getPlayerId(conn, sender);
        const p   = await getOrCreatePlayer(pId);
        const sub = (args[0] || 'info').toLowerCase();

        // ── school info ──────────────────────────────────────────────────────
        if (sub === 'info' || sub === 'list') {
            const lines = [`🎓 *WEIRDOS WORLD UNIVERSITY*`, ``, `Available courses:`, ``];
            for (const [id, c] of Object.entries(SCHOOL_COURSES)) {
                const hasDeg = p.degrees.find(d => d.startsWith(id));
                const lvl    = hasDeg ? parseInt(hasDeg.split('_')[1]) : 0;
                const nextFee = lvl < 3 ? fmtMoney(c.fees[lvl]) : null;
                lines.push(`${c.icon} *${c.name}* (${id}) — ${hasDeg ? `✅ ${LEVEL_NAMES[lvl]} obtained` : 'Not enrolled'}`);
                lines.push(`   Perk L1: ${c.perk[0]}`);
                if (nextFee) lines.push(`   Next enrollment fee: *${nextFee}*`);
            }
            lines.push(``, `*Commands:*`);
            lines.push(`• *school enroll <course>* — start a course`);
            lines.push(`• *school status* — check progress`);
            lines.push(`• *school exam* — take your exam when ready`);
            lines.push(`• *school degrees* — view all your qualifications`);
            lines.push(``, `🧠 Your Intelligence: *${p.intelligence || 1}*`);
            return conn.sendMessage(from, { text: lines.join('\n') }, { quoted: mek });
        }

        // ── school enroll ────────────────────────────────────────────────────
        if (sub === 'enroll') {
            const courseId = (args[1] || '').toLowerCase().replace(/\s+/g,'');
            const course   = SCHOOL_COURSES[courseId];
            if (!course) return conn.sendMessage(from, { text: `❌ Course not found. Try: ${Object.keys(SCHOOL_COURSES).join(', ')}` }, { quoted: mek });
            if (p.education?.course) return conn.sendMessage(from, { text: `📚 You're already enrolled in *${SCHOOL_COURSES[p.education.course]?.name || p.education.course}*.\nFinish it first or use *school drop*.` }, { quoted: mek });

            // Find current max level for this course
            const existing    = p.degrees.find(d => d.startsWith(courseId));
            const currentLvl  = existing ? parseInt(existing.split('_')[1]) : 0;
            if (currentLvl >= 3) return conn.sendMessage(from, { text: `🎓 You already have a full Degree in ${course.name}!` }, { quoted: mek });
            const nextLvl = currentLvl + 1;

            // ── Enrollment fee ────────────────────────────────────────────────
            const enrollFee = course.fees[nextLvl - 1];
            if (p.money < enrollFee) return conn.sendMessage(from, { text: [
                `❌ *Enrollment Declined — Insufficient Funds*`,``,
                `${course.icon} *${course.name} ${LEVEL_NAMES[nextLvl]}* enrollment fee: *${fmtMoney(enrollFee)}*`,
                `Your wallet: ${fmtMoney(p.money)}`,``,
                `_Save up and try again._`
            ].join('\n') }, { quoted: mek });

            p.money -= enrollFee;
            p.moneySpent = (p.moneySpent || 0) + enrollFee;
            logFinancial(p, `School enrollment: ${course.name} ${LEVEL_NAMES[nextLvl]}`, -enrollFee);
            p.education = { course: courseId, level: nextLvl, startedAt: now(), examReady: false, examsTaken: 0 };
            await p.save();
            const durationMin = course.duration[nextLvl - 1];
            return conn.sendMessage(from, { text: [
                `📚 *ENROLLED: ${course.icon} ${course.name} — ${LEVEL_NAMES[nextLvl]}*`,``,
                `💳 Enrollment fee paid: *${fmtMoney(enrollFee)}*`,
                `Study duration: *${durationMin >= 60 ? `${durationMin/60}h` : `${durationMin}min`}*`,
                `After studying, take the exam with: *school exam*`,``,
                `Perks on completion: _${course.perk[nextLvl-1]}_`
            ].join('\n') }, { quoted: mek });
        }

        // ── school status ────────────────────────────────────────────────────
        if (sub === 'status') {
            if (!p.education?.course) return conn.sendMessage(from, { text: `You're not enrolled. Use *school enroll <course>*` }, { quoted: mek });
            const course   = SCHOOL_COURSES[p.education.course];
            const lvl      = p.education.level;
            const durationMs = (course.duration[lvl-1] || 60) * 60 * 1000;
            const elapsed    = now() - (p.education.startedAt || now());
            const pct        = Math.min(100, Math.floor(elapsed / durationMs * 100));
            const ready      = elapsed >= durationMs;
            if (ready && !p.education.examReady) { p.education.examReady = true; await p.save(); }
            const bar = '█'.repeat(Math.floor(pct/10)) + '░'.repeat(10 - Math.floor(pct/10));
            return conn.sendMessage(from, { text: [
                `📚 *${course.icon} ${course.name} — ${LEVEL_NAMES[lvl]}*`,``,
                `Progress: ${bar} ${pct}%`,
                ready ? `✅ *Study complete! Take your exam: school exam*` : `⏳ Ready in: ${shortTime(durationMs - elapsed)}`,
                ``, `Perk on pass: _${course.perk[lvl-1]}_`
            ].join('\n') }, { quoted: mek });
        }

        // ── school exam ──────────────────────────────────────────────────────
        if (sub === 'exam') {
            if (!p.education?.course) return conn.sendMessage(from, { text: `You're not enrolled.` }, { quoted: mek });
            const course   = SCHOOL_COURSES[p.education.course];
            const lvl      = p.education.level;
            const durationMs = (course.duration[lvl-1] || 60) * 60 * 1000;
            if (now() - (p.education.startedAt || 0) < durationMs)
                return conn.sendMessage(from, { text: `⏳ You haven't finished studying yet. Check *school status*.` }, { quoted: mek });

            p.education.examsTaken = (p.education.examsTaken || 0) + 1;
            // Intelligence bonus improves pass rate slightly
            const intBonus = Math.min(0.15, (p.intelligence || 1) * 0.005);
            const passRate = Math.min(0.90, (EXAM_PASS_RATE[lvl] || 0.65) + intBonus);
            const passed   = Math.random() < passRate;

            if (passed) {
                // Grant degree
                p.degrees = p.degrees.filter(d => !d.startsWith(p.education.course));
                p.degrees.push(`${p.education.course}_${lvl}`);
                p.intelligence = (p.intelligence || 1) + course.intGain[lvl - 1];
                p.education    = null;
                await p.save();
                logGlobal('🎓', `*${p.username || pId}* just earned a *${LEVEL_NAMES[lvl]} in ${course.name}*! 🎓`);
                return conn.sendMessage(from, { text: [
                    `🎓 *EXAM PASSED!*`,``,
                    `${course.icon} *${LEVEL_NAMES[lvl]} in ${course.name}* awarded!`,
                    `🧠 Intelligence +${course.intGain[lvl-1]} → *${p.intelligence}*`,``,
                    `✨ Perk unlocked: *${course.perk[lvl-1]}*`,``,
                    lvl < 3 ? `Enroll in Level ${lvl+1} with: *school enroll ${p.education?.course || ''}*` : `🏆 You have the highest qualification in ${course.name}!`
                ].join('\n') }, { quoted: mek });
            } else {
                // Failed — can retry after 30 min
                p.education.startedAt = now() + (30 * 60 * 1000) - durationMs; // reset so they can retake in 30min
                await p.save();
                return conn.sendMessage(from, { text: [
                    `❌ *EXAM FAILED*`,``,
                    `You didn't pass the ${LEVEL_NAMES[lvl]} exam for ${course.name}.`,
                    `Pass rate: ${(passRate*100).toFixed(0)}% (Intelligence helps!)`,``,
                    `You can retake in *30 minutes*.`,
                    `_Tip: Higher intelligence = better pass chance._`
                ].join('\n') }, { quoted: mek });
            }
        }

        // ── school drop ──────────────────────────────────────────────────────
        if (sub === 'drop') {
            if (!p.education?.course) return conn.sendMessage(from, { text: `You're not enrolled in anything.` }, { quoted: mek });
            const name = SCHOOL_COURSES[p.education.course]?.name || p.education.course;
            p.education = null;
            await p.save();
            return conn.sendMessage(from, { text: `📋 Dropped out of *${name}*. Progress lost.` }, { quoted: mek });
        }

        // ── school degrees ───────────────────────────────────────────────────
        if (sub === 'degrees') {
            if (!p.degrees.length) return conn.sendMessage(from, { text: `🎓 No degrees yet. Enroll with *school enroll <course>*` }, { quoted: mek });
            const lines = [`🎓 *YOUR QUALIFICATIONS*`, ``];
            for (const d of p.degrees) {
                const [cId, lStr] = d.split('_');
                const l = parseInt(lStr);
                const c = SCHOOL_COURSES[cId];
                if (c) lines.push(`${c.icon} *${LEVEL_NAMES[l]} in ${c.name}*\n   Perk: ${c.perk[l-1]}`);
            }
            lines.push(``, `🧠 Total Intelligence: *${p.intelligence || 1}*`);
            return conn.sendMessage(from, { text: lines.join('\n') }, { quoted: mek });
        }

        return conn.sendMessage(from, { text: `Usage: school info | enroll <course> | status | exam | drop | degrees` }, { quoted: mek });
    } catch(e) { console.error('school error', e); }
});

