        p.money -= amount; 
        p.moneySpent += amount; 
        let winAmount = 0;
        let resultMsg = '';

        if (game === 'slots') {
            const symbols = ['🍎', '🍒', '🍇', '💎', '7️⃣'];
            const r1 = symbols[Math.floor(Math.random() * symbols.length)];
