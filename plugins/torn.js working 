            await el.save();
            p.lastVoteAt   = now();
            p.cityVotedFor = targetId;
            await p.save();
            return conn.sendMessage(from, { text: `🗳️ Vote cast for @${targetId}! Results announced when election closes.`, mentions: [toJid(targetId)] }, { quoted: mek });
