cmd({ pattern: 'race', desc: 'race create|join|start|status|leaderboard', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
    try {
        const pId = await getPlayerId(conn, sender);
        const p   = await getOrCreatePlayer(pId);
        const sub = (args[0] || 'status').toLowerCase();

        if (sub === 'create') {
            if (!p.activeCar) return conn.sendMessage(from, { text: `Select a car first: *car select <id>*` }, { quoted: mek });
            const entryFee = parseInt(args[1]) || 5000;
            if (p.money < entryFee) return conn.sendMessage(from, { text: `Not enough to cover entry fee of ${fmtMoney(entryFee)}.` }, { quoted: mek });
            const track    = RACE_TRACKS[Math.floor(Math.random() * RACE_TRACKS.length)];
            const raceId   = `R${Date.now().toString(36).toUpperCase()}`;
            const myCar    = (p.cars || []).find(x => x.id === p.activeCar);
            p.money -= entryFee;
            const race = new CarRace({
                raceId, track, city: normLoc(p.location), entryFee, prizePool: entryFee,
                players: [{ playerId: pId, carId: p.activeCar, carName: myCar?.name, speed: myCar?.speed || 50, handling: myCar?.handling || 50 }]
            });
            await race.save(); await p.save();
            return conn.sendMessage(from, { text: [`🏁 *RACE CREATED!*`,``,`ID: *${raceId}*`,`Track: ${track}`,`Entry fee: ${fmtMoney(entryFee)}`,`Slots: 1/${race.maxSlots}`,``,`Others join: *race join ${raceId}*`,`Start when ready: *race start ${raceId}*`,`_(AI fills empty slots at start)_`].join('\n') }, { quoted: mek });
        }

        if (sub === 'join') {
            const raceId = (args[1] || '').toUpperCase();
            const race   = await CarRace.findOne({ raceId, status: 'open' }).exec();
            if (!race) return conn.sendMessage(from, { text: `Race *${raceId}* not found or already started.` }, { quoted: mek });
            if (race.players.find(x => x.playerId === pId)) return conn.sendMessage(from, { text: `You're already in this race!` }, { quoted: mek });
            if (race.players.length >= race.maxSlots) return conn.sendMessage(from, { text: `Race is full (${race.maxSlots}/${race.maxSlots}).` }, { quoted: mek });
            if (!p.activeCar) return conn.sendMessage(from, { text: `Select a car first: *car select <id>*` }, { quoted: mek });
            if (p.money < race.entryFee) return conn.sendMessage(from, { text: `Entry fee: ${fmtMoney(race.entryFee)}. You have ${fmtMoney(p.money)}.` }, { quoted: mek });
            const myCar = (p.cars || []).find(x => x.id === p.activeCar);
            p.money -= race.entryFee;
            race.prizePool += race.entryFee;
            race.players.push({ playerId: pId, carId: p.activeCar, carName: myCar?.name, speed: myCar?.speed || 50, handling: myCar?.handling || 50 });
            await race.save(); await p.save();
            return conn.sendMessage(from, { text: `🏁 Joined race *${raceId}*! Slots: ${race.players.length}/${race.maxSlots}\nPrize pool: ${fmtMoney(race.prizePool)}` }, { quoted: mek });
        }

        if (sub === 'start') {
            const raceId = (args[1] || '').toUpperCase();
            const race   = await CarRace.findOne({ raceId, status: 'open' }).exec();
            if (!race) return conn.sendMessage(from, { text: `Race *${raceId}* not found.` }, { quoted: mek });
            if (race.players[0]?.playerId !== pId) return conn.sendMessage(from, { text: `Only the race creator can start it.` }, { quoted: mek });

            // Fill empty slots with AI
            const slotsNeeded = race.maxSlots - race.players.length;
            for (let i = 0; i < slotsNeeded; i++) {
                const aiName  = AI_DRIVERS[Math.floor(Math.random() * AI_DRIVERS.length)];
                const aiSpeed = 40 + Math.floor(Math.random() * 55);
                const aiHand  = 40 + Math.floor(Math.random() * 55);
                race.players.push({ playerId: `AI_${i}`, carId: 'ai', carName: `AI Car`, speed: aiSpeed, handling: aiHand, isAI: true, name: aiName });
                race.prizePool += race.entryFee; // AI also contributes to pool
            }

            // Simulate race — each player gets a score based on speed + handling + luck
            const scored = race.players.map(pl => {
                const luck  = 0.80 + Math.random() * 0.40;
                const score = (pl.speed * 0.6 + pl.handling * 0.4) * luck;
                return { ...pl, score: Math.floor(score) };
            }).sort((a, b) => b.score - a.score);

            race.results  = scored;
            race.status   = 'finished';
            race.startedAt = now();
            await race.save();

            // Pay out winners (1st 60%, 2nd 25%, 3rd 15%)
            const payouts = [0.60, 0.25, 0.15];
            const resultLines = [`🏁 *RACE RESULT — ${race.track}*`, ``];
            const medals = ['🥇','🥈','🥉'];

            for (let i = 0; i < Math.min(scored.length, 6); i++) {
                const pl      = scored[i];
                const isAI    = pl.isAI;
                const medal   = medals[i] || `${i+1}.`;
                const payout  = i < 3 ? Math.floor(race.prizePool * payouts[i]) : 0;
                const label   = isAI ? `🤖 ${pl.name}` : `@${pl.playerId}`;
                resultLines.push(`${medal} ${label} — Score: ${pl.score}${payout > 0 && !isAI ? ` | 💰 +${fmtMoney(payout)}` : ''}`);

                if (!isAI && payout > 0) {
                    const winner = await getOrCreatePlayer(pl.playerId);
                    winner.money += payout;
                    winner.racesWon = (winner.racesWon || 0) + (i === 0 ? 1 : 0);
                    const wCar = (winner.cars || []).find(c => c.id === pl.carId);
                    if (wCar && i === 0) wCar.wins = (wCar.wins || 0) + 1;
                    addTaxableIncome(winner, payout);
                    logFinancial(winner, `Race ${i+1}st place (${race.track})`, payout);
                    await winner.save();
                } else if (!isAI) {
                    const loser = await getOrCreatePlayer(pl.playerId);
                    loser.racesLost = (loser.racesLost || 0) + 1;
                    await loser.save();
                }
            }

            resultLines.push(``, `💰 Total prize pool: ${fmtMoney(race.prizePool)}`);
            const mentions = scored.filter(s => !s.isAI).map(s => toJid(s.playerId));
            logGlobal('🏁', `Race on *${race.track}* finished! Winner: ${scored[0].isAI ? scored[0].name : `@${scored[0].playerId}`}`);
            return conn.sendMessage(from, { text: resultLines.join('\n'), mentions }, { quoted: mek });
        }

        if (sub === 'leaderboard') {
            const top = await Player.find({ racesWon: { $gt: 0 } }).sort({ racesWon: -1 }).limit(10).exec();
            if (!top.length) return conn.sendMessage(from, { text: `No race results yet. Create a race: *race create*` }, { quoted: mek });
            const lines = [`🏁 *RACE LEADERBOARD*`, ``];
            top.forEach((pl, i) => lines.push(`${i+1}. *${pl.username || pl._id}* — ${pl.racesWon} wins | ${pl.racesLost || 0} losses`));
            return conn.sendMessage(from, { text: lines.join('\n') }, { quoted: mek });
        }

        // status — show open races
        const openRaces = await CarRace.find({ status: 'open' }).limit(10).exec();
        if (!openRaces.length) return conn.sendMessage(from, { text: `No open races right now.\nCreate one: *race create [entry_fee]*` }, { quoted: mek });
        const lines = [`🏁 *OPEN RACES*`, ``];
        for (const r of openRaces) {
            lines.push(`ID: *${r.raceId}* | Track: ${r.track} | Entry: ${fmtMoney(r.entryFee)} | Slots: ${r.players.length}/${r.maxSlots}\nJoin: *race join ${r.raceId}*`);
        }
        return conn.sendMessage(from, { text: lines.join('\n') }, { quoted: mek });
    } catch(e) { console.error('race error', e); }
});

