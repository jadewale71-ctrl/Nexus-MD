cmd({ pattern: 'divorce', desc: 'Divorce your spouse (wife takes 50% of combined assets)', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from }) => {
    try {
        const pId = await getPlayerId(conn, sender);
        const p   = await getOrCreatePlayer(pId);

        if (isHospitalized(p)) return conn.sendMessage(from, { text: `Action restricted.` }, { quoted: mek });
        if (!p.spouse) return conn.sendMessage(from, { text: `You are not married.` }, { quoted: mek });

        const ex    = await getOrCreatePlayer(p.spouse);
        const exId  = ex._id;

        // Identify husband and wife
        const husband = p.marriageRole === 'husband' ? p   : ex;
        const wife    = p.marriageRole === 'wife'    ? p   : ex;

        // ── Calculate combined total assets ───────────────────────────────────
        // Wallet + Bank for both players
        let combinedCash = (husband.money || 0) + (husband.bank || 0)
                         + (wife.money    || 0) + (wife.bank    || 0);

        // Property values — look up each property in DEFAULT_SHOP
        function getPropertyValue(player) {
            let total = 0;
            const props = player.properties;
            if (!props) return 0;
            const entries = props instanceof Map ? [...props.entries()] : Object.entries(props);
            for (const [propId, qty] of entries) {
                if (!qty || qty <= 0) continue;
                const shopItem = DEFAULT_SHOP.find(s => s.id === propId);
                if (shopItem) total += shopItem.price * qty;
            }
            return total;
        }

        const husbandPropValue = getPropertyValue(husband);
        const wifePropValue    = getPropertyValue(wife);
        const combinedTotal    = combinedCash + husbandPropValue + wifePropValue;
        const wifeSettlement   = Math.floor(combinedTotal * 0.50);

        // ── Transfer settlement to wife ───────────────────────────────────────
        // Drain husband first (wallet then bank), then wife's own assets stay
        let remaining = wifeSettlement - (wife.money || 0) - (wife.bank || 0);
        // Wife already has her own — settlement is the TOTAL she ends up with
        // So we need to transfer: wifeSettlement - wife's current holdings
        const wifeCurrentTotal = (wife.money || 0) + (wife.bank || 0);
        const transferAmount   = Math.max(0, wifeSettlement - wifeCurrentTotal);

        // Take from husband: wallet first, then bank, then liquidate properties
        let toTake = transferAmount;
        const fromWallet = Math.min(husband.money || 0, toTake);
        husband.money = (husband.money || 0) - fromWallet;
        toTake -= fromWallet;

        if (toTake > 0) {
            const fromBank = Math.min(husband.bank || 0, toTake);
            husband.bank = (husband.bank || 0) - fromBank;
            toTake -= fromBank;
        }

        if (toTake > 0 && husbandPropValue > 0) {
            // Liquidate husband's properties at market value until debt is paid
            const props = husband.properties instanceof Map ? [...husband.properties.entries()] : Object.entries(husband.properties || {});
            for (const [propId, qty] of props) {
                if (toTake <= 0) break;
                if (!qty || qty <= 0) continue;
                const shopItem = DEFAULT_SHOP.find(s => s.id === propId);
                if (!shopItem) continue;
                const sellValue = shopItem.price * qty;
                if (sellValue <= toTake) {
                    toTake -= sellValue;
                    if (husband.properties instanceof Map) husband.properties.set(propId, 0);
                    else husband.properties[propId] = 0;
                } else {
                    const sellQty = Math.ceil(toTake / shopItem.price);
                    toTake -= shopItem.price * sellQty;
                    const newQty = qty - sellQty;
                    if (husband.properties instanceof Map) husband.properties.set(propId, Math.max(0, newQty));
                    else husband.properties[propId] = Math.max(0, newQty);
                }
            }
        }

        // Give wife the transfer
        wife.money = (wife.money || 0) + transferAmount;

        const wifeEndTotal = (wife.money || 0) + (wife.bank || 0);

        // ── Record in exes list for both players ─────────────────────────────
        p.exes  = p.exes  || [];
        ex.exes = ex.exes || [];
        p.exes.push({  id: exId,       role: p.marriageRole  || 'unknown', divorcedAt: now() });
        ex.exes.push({ id: pId,        role: ex.marriageRole || 'unknown', divorcedAt: now() });

        // ── Clear marriage fields ─────────────────────────────────────────────
        p.spouse   = null; p.marriageRole = null; p.marriedAt = 0;
        ex.spouse  = null; ex.marriageRole = null; ex.marriedAt = 0;

        logAction(p,  `Divorced @${exId}`);
        logAction(ex, `Divorced by @${pId}`);
        logFinancial(wife,    `Divorce settlement received`,   transferAmount);
        logFinancial(husband, `Divorce settlement paid out`,  -transferAmount);
        logGlobal('💔', `*${husband.username || husband._id}* and *${wife.username || wife._id}* got divorced. The wife walked away with ${fmtMoney(wifeEndTotal)}.`);

        await p.save();
        await ex.save();

        const titleMsg = checkTitles(p);
        return conn.sendMessage(from, {
            text: [
                `💔 *DIVORCE FINALISED*`,
                ``,
                `👑 Ex-Husband: @${husband._id}`,
                `💍 Ex-Wife:    @${wife._id}`,
                ``,
                `💰 *Combined assets at time of divorce:*`,
                `   💵 Cash (both): ${fmtMoney(combinedCash)}`,
                `   🏠 Properties (both): ${fmtMoney(husbandPropValue + wifePropValue)}`,
                `   Total: *${fmtMoney(combinedTotal)}*`,
                ``,
                `⚖️ *Wife's 50% settlement: ${fmtMoney(wifeSettlement)}*`,
                `   Transferred to @${wife._id}: ${fmtMoney(transferAmount)}`,
                ``,
                `😭 @${husband._id} — should have stayed loyal.`,
            ].join('\n'),
            mentions: [toJid(husband._id), toJid(wife._id)]
        }, { quoted: mek });
    } catch (e) { console.error('divorce error', e); }
});


