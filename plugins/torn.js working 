const FACTION_LEVEL_XP   = [0,500,1500,3500,7500,15000,30000,60000,120000,250000];
const FACTION_MAX_MEMBERS = [10,15,20,25,30,40,50,60,75,100];

async function addFactionXP(fac, xp) {
    fac.xp = (fac.xp || 0) + xp;
    const currentLevel = fac.level || 1;
    if (currentLevel < 10 && fac.xp >= FACTION_LEVEL_XP[currentLevel]) {
        fac.level      = currentLevel + 1;
        fac.maxMembers = FACTION_MAX_MEMBERS[currentLevel];
        logGlobal('🏢', `*${fac.name}* leveled up to *Faction Level ${fac.level}*! Max members: ${fac.maxMembers}`);
    }
}

