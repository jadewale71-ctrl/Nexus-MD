// COMMAND: income — Full breakdown of every source of income for a player
// =============================================================================
cmd({ pattern: 'income', desc: 'See a full breakdown of all your income sources', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
    try {
        const senderId = await getPlayerId(conn, sender);
        const CREATOR_ID = '2348084644182';
        let id = senderId;
        if (senderId === CREATOR_ID) {
            const t = await getTargetId(conn, mek, args, 0).catch(() => null);
            if (t && t !== senderId) id = t;
        }
        const p = await getOrCreatePlayer(id);

        initMarket();
        const wageM = global.WAGE_INDEX ?? 1.0;
        const econM = global.ECON_INDEX ?? 1.0;
        const lines = [`💰 *INCOME BREAKDOWN — ${p.username || '@'+id}*`, ``];

        // ── CAREER SALARY (passive, hourly) ───────────────────────────────────
        if (p.career?.jobId) {
            const job    = CAREER_JOBS[p.career.jobId];
            const rank   = Math.min(5, p.career.rank || 1);
            const salary = getCareerHourlySalary(p);
            lines.push(`${job?.icon || '💼'} *Career: ${job?.name || p.career.jobId} (${JOB_RANK_NAMES[rank-1]})*`);
            lines.push(`   Salary: *${fmtMoney(salary)}/hr* = ${fmtMoney(salary * 24)}/day`);
            lines.push(``);
        }

        // ── JOBS (work command) ───────────────────────────────────────────────
        lines.push(`👔 *Jobs (work command)*`);
        for (const job of JOBS) {
            const { min, max } = liveJobPay(job.rewardMin, job.rewardMax);
            lines.push(`   ${job.name}: ${fmtMoney(min)}–${fmtMoney(max)} per shift`);
        }
        lines.push(``);

        // ── PROPERTY PASSIVE INCOME ───────────────────────────────────────────
        const ownedProps = p.properties instanceof Map ? [...p.properties.entries()] : Object.entries(p.properties || {});
        const propIncome = ownedProps.filter(([,q]) => q > 0);
        if (propIncome.length > 0) {
            lines.push(`🏠 *Properties (passive, per 5 min)*`);
            let totalPropPerHour = 0;
            for (const [propId, qty] of propIncome) {
                const shopIt = DEFAULT_SHOP.find(s => s.id === propId);
                if (!shopIt || !shopIt.incomeRate) continue;
                const liveRate = livePropertyIncome(shopIt.incomeRate);
                const perHour  = liveRate * 12 * qty;
                totalPropPerHour += perHour;
                lines.push(`   ${shopIt.name} ×${qty}: ${fmtMoney(liveRate)}/5min = ${fmtMoney(perHour)}/hr`);
            }
            lines.push(`   📊 Total property: *${fmtMoney(totalPropPerHour)}/hr*`);
            lines.push(``);
        }

        // ── TYCOON ────────────────────────────────────────────────────────────
        if (p.tycoon) {
            const TYCOON_UPGRADES = [
                { id: 'droppers',    name: 'Droppers',       incomePerMin: 50   },
                { id: 'conveyor',    name: 'Conveyor Belt',  incomePerMin: 200  },
                { id: 'factory',     name: 'Factory Floor',  incomePerMin: 800  },
                { id: 'vault',       name: 'Money Vault',    incomePerMin: 2500 },
                { id: 'launcher',    name: 'Cash Launcher',  incomePerMin: 8000 },
                { id: 'megafactory', name: 'Mega Factory',   incomePerMin: 35000},
            ];
            const tycoon = p.tycoon instanceof Map ? Object.fromEntries(p.tycoon) : p.tycoon;
            const owned  = TYCOON_UPGRADES.filter(u => tycoon[u.id]);
            if (owned.length > 0) {
                const totalPerMin = owned.reduce((a,u) => a + u.incomePerMin, 0);
                lines.push(`🏭 *Tycoon (claim anytime)*`);
                for (const u of owned) lines.push(`   ${u.name}: +${fmtMoney(u.incomePerMin)}/min`);
                lines.push(`   📊 Total tycoon: *${fmtMoney(totalPerMin)}/min = ${fmtMoney(totalPerMin*60)}/hr*`);
                lines.push(``);
            }
        }

        // ── INVESTMENTS ───────────────────────────────────────────────────────
        const investments = p.investments || [];
        if (investments.length > 0) {
            lines.push(`📈 *Active Investments*`);
            for (const inv of investments) {
                const termStr = inv.termMs === 3600000 ? '1h' : inv.termMs === 6*3600000 ? '6h' : '24h';
                const payout  = Math.floor(inv.amount * (1 + inv.rate));
                const matures = inv.boughtAt + inv.termMs;
                const ready   = matures <= now();
                lines.push(`   ${fmtMoney(inv.amount)} @ ${(inv.rate*100).toFixed(1)}% (${termStr}) → ${fmtMoney(payout)} ${ready ? '✅ READY' : `⏳ ${shortTime(matures - now())}`}`);
            }
            lines.push(``);
        }

        // ── WALL STREET RATES (current) ───────────────────────────────────────
        const r1h  = +(0.05  * Math.max(0.4, Math.min(2.0, econM))).toFixed(3);
        const r6h  = +(0.18  * Math.max(0.4, Math.min(2.0, econM))).toFixed(3);
        const r24h = +(0.5   * Math.max(0.4, Math.min(2.0, econM))).toFixed(3);
        lines.push(`💹 *Wall Street Rates (live)*`);
        lines.push(`   1h: ${(r1h*100).toFixed(1)}% | 6h: ${(r6h*100).toFixed(1)}% | 24h: ${(r24h*100).toFixed(1)}%`);
        lines.push(``);

        // ── CRIME REWARDS (current) ───────────────────────────────────────────
        lines.push(`🦹 *Crime Rewards (live)*`);
        for (const crime of CRIMES) {
            const { min: cMin, max: cMax } = liveCrimeReward(crime.rewardMin, crime.rewardMax);
            lines.push(`   ${crime.name}: ${fmtMoney(cMin)}–${fmtMoney(cMax)}`);
        }
        lines.push(``);

        // ── HUNTING (current) ─────────────────────────────────────────────────
        const regionPrey = PREY_LIST.filter(pr => pr.region === normLoc(p.location));
        if (regionPrey.length > 0) {
            lines.push(`🏹 *Hunting (${p.location})*`);
            for (const pr of regionPrey) {
