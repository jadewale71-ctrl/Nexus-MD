            }
        }
        return conn.sendMessage(from, { text: `Usage: factionheist plan | factionheist go <number>` }, { quoted: mek });
    } catch(e) { console.error('factionheist error', e); }
});

cmd({ pattern: 'factionterritory', desc: 'Claim or view city territory', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
    try {
        const pId = await getPlayerId(conn, sender);
        const p   = await getOrCreatePlayer(pId);
        if (!p.faction) return conn.sendMessage(from, { text: `You're not in a faction.` }, { quoted: mek });
        const f = await Faction.findById(p.faction).exec();
        if ((f.level || 1) < 3) return conn.sendMessage(from, { text: `Territory control requires *Faction Level 3*. You are Level ${f.level || 1}.` }, { quoted: mek });

        const sub    = (args[0] || 'view').toLowerCase();
        const CITIES = ['Weirdos World','Mexico','London','Japan','Switzerland','Dubai','New York','Paris','Lagos','Moscow','Sydney','Rio de Janeiro'];

        if (sub === 'view') {
            const allFactions = await Faction.find({ territory: { $ne: null } }).exec();
            const lines = [`🗺️ *TERRITORY MAP*`, ``];
            for (const city of CITIES) {
                const controller = allFactions.find(fc => fc.territory === city);
                lines.push(`${controller ? `🔴 *${city}* — controlled by *${controller.name}*` : `⬜ *${city}* — unclaimed`}`);
            }
            lines.push(``, `Claim: *factionterritory claim <city>*`);
            if (f.territory) lines.push(`Your territory: *${f.territory}*`);
            return conn.sendMessage(from, { text: lines.join('\n') }, { quoted: mek });
        }

        if (sub === 'claim') {
            if (f.owner !== pId) return conn.sendMessage(from, { text: `Only the faction owner can claim territory.` }, { quoted: mek });
            const cityName = args.slice(1).join(' ').trim();
            const city = CITIES.find(c => c.toLowerCase() === cityName.toLowerCase());
            if (!city) return conn.sendMessage(from, { text: `Unknown city. Use *factionterritory view* to see options.` }, { quoted: mek });

            const CLAIM_CD = 24 * 60 * 60 * 1000;
            if (now() - (f.lastTerritoryAttack || 0) < CLAIM_CD) return conn.sendMessage(from, { text: `⏳ Territory action cooldown: ${shortTime(CLAIM_CD - (now() - (f.lastTerritoryAttack||0)))}` }, { quoted: mek });

            const existing = await Faction.findOne({ territory: city }).exec();
            if (existing && String(existing._id) === String(f._id)) return conn.sendMessage(from, { text: `You already control *${city}*.` }, { quoted: mek });

            f.lastTerritoryAttack = now();

            if (!existing) {
                f.territory = city;
                await addFactionXP(f, 500); await f.save();
                logGlobal('🗺️', `*${f.name}* claimed *${city}* as their territory!`);
                return conn.sendMessage(from, { text: [`🗺️ *TERRITORY CLAIMED!*`,``,`*${f.name}* now controls *${city}*!`,`+500 Faction XP`].join('\n') }, { quoted: mek });
            }

            // Battle for territory — faction power vs faction power
            const myMembers  = await Player.find({ _id: { $in: f.members } }).exec();
            const enMembers  = await Player.find({ _id: { $in: existing.members } }).exec();
            const calcPow    = (mbs) => mbs.reduce((t, mb) => t + (mb.strength||3) + (mb.defense||3) + (mb.speed||3), 0);
            const myPow      = calcPow(myMembers) * (0.85 + Math.random()*0.30);
            const enPow      = calcPow(enMembers) * (0.85 + Math.random()*0.30);
            const won        = myPow > enPow;

            if (won) {
                existing.territory = null;
                f.territory        = city;
                f.warsWon = (f.warsWon||0) + 1;
                existing.warsLost = (existing.warsLost||0) + 1;
                await addFactionXP(f, 1000); await f.save(); await existing.save();
                logGlobal('🗺️', `*${f.name}* seized *${city}* from *${existing.name}* in a territory war!`);
                return conn.sendMessage(from, { text: [`⚔️ *TERRITORY SEIZED!*`,``,`*${f.name}* overpowered *${existing.name}*!`,`*${city}* is now yours.`,`+1000 Faction XP`].join('\n') }, { quoted: mek });
            } else {
                f.warsLost = (f.warsLost||0) + 1;
                existing.warsWon = (existing.warsWon||0) + 1;
                await f.save(); await existing.save();
                return conn.sendMessage(from, { text: [`⚔️ *TERRITORY ATTACK FAILED*`,``,`*${existing.name}* defended *${city}* successfully.`,`Try again in 24 hours.`].join('\n') }, { quoted: mek });
            }
        }
        return conn.sendMessage(from, { text: `Usage: factionterritory view | claim <city>` }, { quoted: mek });
    } catch(e) { console.error('factionterritory error', e); }
});

