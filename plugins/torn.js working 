async function handleEconIndexCmd(conn, mek, m, { from }) {
    try {
        initMarket();
        const econ = global.ECON_INDEX ?? 1.0;
        const wage = global.WAGE_INDEX ?? 1.0;
        const nextTick = Math.max(0, 20*60*1000 - (Date.now() - (global.LAST_MARKET_UPDATE || Date.now())));

        // Most moved items — biggest gains and biggest drops
        const movers = Object.entries(global.MARKET_PRICES || {})
            .map(([id, mult]) => ({ id, mult }))
            .sort((a,b) => b.mult - a.mult);
        const top3Up   = movers.slice(0,3).map(m => `  📈 ${m.id}: +${((m.mult-1)*100).toFixed(0)}%`);
        const top3Down = [...movers].reverse().slice(0,3).map(m => `  📉 ${m.id}: ${((m.mult-1)*100).toFixed(0)}%`);

        const econBar = (() => {
            const n = Math.min(10, Math.round(((econ - 0.4) / (2.5 - 0.4)) * 10));
            return '█'.repeat(n) + '░'.repeat(10 - n);
        })();
        const wageBar = (() => {
            const n = Math.min(10, Math.round(((wage - 0.5) / (2.0 - 0.5)) * 10));
            return '█'.repeat(n) + '░'.repeat(10 - n);
        })();

        const txt = [
            `📊 *WEIRDOS WORLD — MARKET DASHBOARD*`,
            ``,
            `🌍 *Economy:* ${econLabel()}`,
            `   Index: ${econ.toFixed(3)}  |  ${econBar}`,
            ``,
            `💼 *Labour Market*`,
            `   Wage Index: ${wage.toFixed(3)}  |  ${wageBar}`,
            `   ${wage > 1.15 ? '📈 High wages — work pays more right now' : wage < 0.85 ? '📉 Low wages — labour market is down' : '📊 Wages stable'}`,
            ``,
            `📈 *Biggest Price Rises:*`,
            ...top3Up,
            ``,
            `📉 *Biggest Price Drops:*`,
            ...top3Down,
            ``,
            `🔄 Next market update: ${nextTick > 0 ? Math.ceil(nextTick/60000)+' min' : 'imminent'}`,
            ``,
            `_Prices update every 20 minutes. Buy low, sell high._`,
            `_Investments, wages, crime, hunt rewards, and shop prices all fluctuate._`,
        ].join('\n');

        return conn.sendMessage(from, { text: txt }, { quoted: mek });
    } catch(e) { console.error('econindex error', e); }
}
