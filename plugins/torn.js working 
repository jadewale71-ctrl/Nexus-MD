                `Current card: ${cardEmoji(current)} *${cardName(current)}* (${current})`,``,
                `Guess if the next card is higher or lower!`,
                `Usage: *highlow <amount> higher* or *highlow <amount> lower*`,``,
                `• Correct guess = *2x* your bet`,
                `• 5 in a row = *jackpot bonus!*`,
                `• Ties = refund`
            ].join('\n') }, { quoted: mek });
        }

        if (p.money < amount) return conn.sendMessage(from, { text: `Not enough cash. You have ${fmtMoney(p.money)}.` }, { quoted: mek });

        const current = global.highLowCard;
        const next    = Math.floor(Math.random() * 13) + 1;
        global.highLowCard = next;

        const guessHigher = guess === 'higher' || guess === 'h';
        const isTie       = next === current;
        const isCorrect   = isTie ? false : (guessHigher ? next > current : next < current);

        p.cooldowns = p.cooldowns || {};
        const streak = isTie ? (p.cooldowns.hlStreak || 0) : isCorrect ? (p.cooldowns.hlStreak || 0) + 1 : 0;
        p.cooldowns.hlStreak = streak;

        let result = `🃏 *HIGH / LOW*\n\nCurrent: ${cardEmoji(current)} *${cardName(current)}* (${current})\nNext card: ${cardEmoji(next)} *${cardName(next)}* (${next})\n\n`;

        if (isTie) {
            result += `🤝 *TIE!* Your ${fmtMoney(amount)} is refunded. Streak maintained.`;
        } else if (isCorrect) {
            let win = amount * 2;
            let bonus = '';
            if (streak >= 5) {
                const jackpotSlice = Math.floor(global.casinoJackpot * 0.30);
                win += jackpotSlice;
                global.casinoJackpot = Math.floor(global.casinoJackpot * 0.70);
                bonus = `\n🎉 *5-STREAK JACKPOT! +${fmtMoney(jackpotSlice)} bonus!*`;
                p.cooldowns.hlStreak = 0;
            }
            const profit = win - amount;
            p.money += profit;
            addTaxableIncome(p, profit);
            result += `✅ *CORRECT!* You win *${fmtMoney(win)}!*${bonus}\n🔥 Streak: ${streak}`;
            logFinancial(p, `HighLow win`, profit);
        } else {
            p.money -= amount;
            global.casinoJackpot += Math.floor(amount * 0.10);
            p.cooldowns.hlStreak = 0;
            result += `❌ *WRONG!* You lose ${fmtMoney(amount)}. Streak broken.`;
        }

        await p.save();
        return conn.sendMessage(from, { text: result }, { quoted: mek });
    } catch(e) { console.error('highlow error', e); }
});

