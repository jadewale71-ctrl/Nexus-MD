async function ensureShop() {
    try {
        await ensureMongo();
        for (let item of DEFAULT_SHOP) {
            // $setOnInsert: only writes fields when the document is first CREATED.
            // If the item already exists in DB (with inflated prices), nothing is overwritten.
            // $set is used only for non-price metadata that should always stay current.
            await ShopItem.updateOne(
                { id: item.id },
                {
                    $setOnInsert: { price: item.price },   // ← never overwrite existing price
                    $set: {
                        name:        item.name,
                        type:        item.type,
                        description: item.description,
                        region:      item.region,
                        maxStock:    item.maxStock,
                        rarity:      item.rarity,
                        atkBonus:    item.atkBonus,
                        defBonus:    item.defBonus,
                        hpBoost:     item.hpBoost,
                        trainBoost:  item.trainBoost,
                        incomeRate:  item.incomeRate,
                        // heal and energy MUST be synced so medkits/drinks work
                        heal:        item.heal   || 0,
                        energy:      item.energy || 0,
                        strBonus:    item.strBonus || 0,
                        spdBonus:    item.spdBonus || 0,
                        dexBonus:    item.dexBonus || 0,
                        gearSlot:    item.gearSlot || null,
                    }
                },
                { upsert: true }
            );
        }
        // After ensuring all items exist, load DB prices back into DEFAULT_SHOP memory array
        // so that all in-memory reads reflect the (possibly inflated) DB state.
        const dbItems = await ShopItem.find({}, { id: 1, price: 1 }).lean().exec();
        const priceMap = {};
        for (const it of dbItems) priceMap[it.id] = it.price;
        for (const it of DEFAULT_SHOP) {
            if (priceMap[it.id] !== undefined) it.price = priceMap[it.id];
        }
    } catch (e) { console.error('ensureShop error', e); }
}
