};
const JOB_RANK_NAMES = ['Junior', 'Mid-Level', 'Senior', 'Lead', 'Director'];
const JOB_RANK_MULT  = [1.0, 1.4, 1.9, 2.6, 3.5];

// ── Salary helper — returns hourly net pay for a player's current job+rank ──
function getCareerHourlySalary(p) {
    if (!p.career?.jobId) return 0;
    const job     = CAREER_JOBS[p.career.jobId];
    const company = COMPANIES[p.career.companyId];
    if (!job) return 0;
    const base  = company ? company.hourlyBase : job.hourlyBase;
    const rank  = Math.min(5, p.career.rank || 1);
    const mult  = JOB_RANK_MULT[rank - 1];
    const intBonus = 1 + Math.max(0, ((p.intelligence || 1) - 1) * 0.01);
    const wageM    = global.WAGE_INDEX ?? 1.0;
    return Math.floor(base * mult * intBonus * wageM);
}

cmd({ pattern: 'career', desc: 'career list | apply <company> | status | resign', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
