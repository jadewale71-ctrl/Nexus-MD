            const job = CAREER_JOBS[company.jobId];
            if (!job) return conn.sendMessage(from, { text: `Job data error.` }, { quoted: mek });

            // Must not already have a job
            if (p.career?.jobId) {
                const cur = COMPANIES[p.career.companyId];
                return conn.sendMessage(from, { text: `You're already employed at *${cur?.name || p.career.companyId}*.\nResign first: *career resign*` }, { quoted: mek });
            }

            // Qualification check
            if (!(p.degrees || []).includes(job.requires)) {
                const [cId, lStr] = job.requires.split('_');
                return conn.sendMessage(from, { text: [
                    `❌ *Application Rejected — Missing Qualification*`,``,
                    `${company.name} requires: *${LEVEL_NAMES[parseInt(lStr)]} in ${SCHOOL_COURSES[cId]?.name}*`,
                    `Enroll: *school enroll ${cId}*`
                ].join('\n') }, { quoted: mek });
            }

            // Application outcome — intelligence and degrees boost acceptance
            const intBoost   = Math.min(0.20, ((p.intelligence || 1) - 1) * 0.01);
            const degBoost   = Math.min(0.10, (p.degrees || []).length * 0.03);
            const acceptProb = Math.min(0.98, company.acceptRate + intBoost + degBoost);
            const accepted   = Math.random() < acceptProb;

            if (!accepted) {
                // Rejection — give specific reason based on gap
                const gap       = (1 - acceptProb + intBoost + degBoost);
                const reason    = gap > 0.40
                    ? `Your qualifications are below what ${company.name} expects for this competitive role.`
                    : gap > 0.20
                    ? `Another candidate scored higher in the interview process.`
                    : `Headcount freeze — the position was filled internally. Try again soon.`;
                return conn.sendMessage(from, { text: [
                    `📋 *APPLICATION DECLINED*`,``,
                    `Company: *${company.name}*`,
                    `Role: *${job.name}*`,``,
                    `Reason: _${reason}_`,``,
                    `💡 Tip: Higher intelligence and more degrees improve your acceptance rate.`,
                    `You can re-apply to any company at any time.`
                ].join('\n') }, { quoted: mek });
            }

            // Accepted
            p.career = {
                jobId:      company.jobId,
                companyId:  compId,
                rank:       1,
                shiftsWorked: 0,
                hiredAt:    now(),
                lastPaidAt: now(),
                lastPromotionAt: now(),
            };
            await p.save();

            const startingSalary = getCareerHourlySalary(p);
            return conn.sendMessage(from, { text: [
                `${company.icon} *HIRED AT ${company.name.toUpperCase()}!*`,``,
                `Role: *${job.name} — ${JOB_RANK_NAMES[0]}*`,
                `📍 Location: ${company.city}`,
                `💰 Starting salary: *${fmtMoney(startingSalary)}/hr*`,
                `_Paid automatically every hour._`,``,
                `Culture: _${company.culture}_`,``,
                `📈 Next promotion: *${job.promotionHours[0]} hours* (${Math.round(job.promotionHours[0]/24)} days) in role`,
                `Check your status: *career status*`
            ].join('\n') }, { quoted: mek });
        }

        // ── career status ─────────────────────────────────────────────────────
        if (sub === 'status') {
            if (!p.career?.jobId) return conn.sendMessage(from, { text: [
                `💼 You don't have a job.`,``,
                `Browse companies: *career list*`,
                `_Requires a university degree to apply._`
            ].join('\n') }, { quoted: mek });

            const job      = CAREER_JOBS[p.career.jobId];
            const company  = COMPANIES[p.career.companyId];
            const rank     = Math.min(5, p.career.rank || 1);
            const salary   = getCareerHourlySalary(p);
            const hoursAtRank = Math.floor((now() - (p.career.lastPromotionAt || p.career.hiredAt || now())) / 3600000);
            const totalHrs = Math.floor((now() - (p.career.hiredAt || now())) / 3600000);
            const nextPromoHrs = job?.promotionHours?.[rank - 1];
            const nextPayIn  = p.career.lastPaidAt ? Math.max(0, 3600000 - (now() - p.career.lastPaidAt)) : 3600000;

            return conn.sendMessage(from, { text: [
                `${company?.icon || '💼'} *${company?.name || p.career.companyId}*`,
                `Role: *${job?.name || p.career.jobId}*`,
                ``,
                `🏅 Rank: *${JOB_RANK_NAMES[rank-1]}* (${rank}/5)`,
                `💰 Salary: *${fmtMoney(salary)}/hr*`,
                `⏱️ Next pay: ${nextPayIn > 0 ? shortTime(nextPayIn) : 'any moment now'}`,
                ``,
                `📅 Total employed: *${totalHrs} hours*`,
                `⏳ At current rank: ${hoursAtRank}h${nextPromoHrs ? ` / ${nextPromoHrs}h until promotion` : ' — MAX RANK'}`,
                nextPromoHrs
                    ? `📈 Promotion to *${JOB_RANK_NAMES[rank]}*: ~${Math.round((nextPromoHrs - hoursAtRank)/24)} days remaining`
                    : `🏆 You've reached the top — *Director*!`,
                ``,
                `🧠 Intelligence bonus: +${Math.max(0,((p.intelligence||1)-1))}% on salary`,
                `💡 Resign: *career resign*`
            ].join('\n') }, { quoted: mek });
        }

        // ── career resign ─────────────────────────────────────────────────────
        if (sub === 'resign') {
            if (!p.career?.jobId) return conn.sendMessage(from, { text: `You don't have a job.` }, { quoted: mek });
            const company = COMPANIES[p.career.companyId];
            const job     = CAREER_JOBS[p.career.jobId];
            // Pay out pending hours (up to 1 hr max on resignation)
            const hoursPending = (now() - (p.career.lastPaidAt || now())) / 3600000;
            let finalPay = 0;
            if (hoursPending >= 0.5) {
                const salary = getCareerHourlySalary(p);
                finalPay = Math.floor(salary * Math.min(hoursPending, 1));
                p.money += finalPay;
                addTaxableIncome(p, finalPay);
                logFinancial(p, `Final pay: ${company?.name}`, finalPay);
            }
            p.career = null;
            await p.save();
            return conn.sendMessage(from, { text: [
                `📋 *Resigned from ${company?.name || 'your job'}.*`,
                finalPay > 0 ? `💰 Final pay: *${fmtMoney(finalPay)}*` : null,
                ``,
                `Browse new opportunities: *career list*`
            ].filter(Boolean).join('\n') }, { quoted: mek });
        }

        return conn.sendMessage(from, { text: `Usage: career list [filter] | career apply <company> | career status | career resign` }, { quoted: mek });
    } catch(e) { console.error('career error', e); }
});
cmd({ pattern: 'car', desc: 'car buy|list|tune|select|mycar|sell — Car system', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
    try {
        const pId = await getPlayerId(conn, sender);
        const p   = await getOrCreatePlayer(pId);
        const sub = (args[0] || 'mycar').toLowerCase();

        if (sub === 'list') {
            const lines = [`🚗 *CAR DEALERSHIP*`, ``];
            for (const [id, c] of Object.entries(CAR_CATALOGUE)) {
                const owned = (p.cars || []).find(x => x.id === id);
                lines.push(`${c.icon} *${c.name}* (${id})\n   💰 ${fmtMoney(livePrice({id, price: c.price}))} | ⚡ Speed: ${c.speed} | 🎯 Handling: ${c.handling}${owned ? ' ✅ Owned' : ''}`);
            }
            lines.push(``, `Buy: *car buy <id>* | Select for race: *car select <id>*`);
            return conn.sendMessage(from, { text: lines.join('\n') }, { quoted: mek });
        }

        if (sub === 'buy') {
            const carId = (args[1] || '').toLowerCase();
            const car   = CAR_CATALOGUE[carId];
            if (!car) return conn.sendMessage(from, { text: `Car not found. Use *car list* to browse.` }, { quoted: mek });
            if ((p.cars || []).find(x => x.id === carId)) return conn.sendMessage(from, { text: `You already own a ${car.name}.` }, { quoted: mek });
            const price = livePrice({ id: carId, price: car.price });
            if (p.money < price) return conn.sendMessage(from, { text: `💸 ${car.name} costs ${fmtMoney(price)}. You have ${fmtMoney(p.money)}.` }, { quoted: mek });
            p.money -= price;
            p.moneySpent += price;
            p.cars = p.cars || [];
            p.cars.push({ id: carId, name: car.name, speed: car.speed, handling: car.handling, tunePoints: 0, wins: 0 });
            if (!p.activeCar) p.activeCar = carId;
            await p.save();
            return conn.sendMessage(from, { text: [`${car.icon} *${car.name} PURCHASED!*`,``,`Speed: ${car.speed} | Handling: ${car.handling}`,`Tune your car with: *car tune <id>*`,`Set as race car: *car select ${carId}*`].join('\n') }, { quoted: mek });
        }

        if (sub === 'tune') {
            const carId = (args[1] || p.activeCar || '').toLowerCase();
            const owned = (p.cars || []).find(x => x.id === carId);
            if (!owned) return conn.sendMessage(from, { text: `You don't own that car. Check *car mycar*.` }, { quoted: mek });
            const TUNE_COST = 50000;
            const engBonus  = p.degrees.includes('engineering_1') ? 2 : 0;
            if (owned.tunePoints >= 10) return conn.sendMessage(from, { text: `🔧 ${owned.name} is already fully tuned (10/10)!` }, { quoted: mek });
            if (p.money < iC(TUNE_COST)) return conn.sendMessage(from, { text: `Tuning costs ${fmtMoney(iC(TUNE_COST))}.` }, { quoted: mek });
            p.money -= iC(TUNE_COST);
            const gain = 1 + engBonus;
            owned.tunePoints = Math.min(10, (owned.tunePoints || 0) + gain);
            owned.speed      = Math.min(100, owned.speed + gain);
            owned.handling   = Math.min(100, owned.handling + gain);
            await p.save();
            return conn.sendMessage(from, { text: [`🔧 *TUNED: ${owned.name}*`,``,`Tune points: ${owned.tunePoints}/10`,`Speed: ${owned.speed} | Handling: ${owned.handling}`,engBonus ? `⚙️ Engineering degree bonus: +${engBonus} extra!` : ``].filter(Boolean).join('\n') }, { quoted: mek });
        }

        if (sub === 'select') {
            const carId = (args[1] || '').toLowerCase();
            if (!(p.cars || []).find(x => x.id === carId)) return conn.sendMessage(from, { text: `You don't own that car.` }, { quoted: mek });
            p.activeCar = carId;
            await p.save();
            const car = CAR_CATALOGUE[carId];
            return conn.sendMessage(from, { text: `${car?.icon} *${car?.name}* selected for racing!` }, { quoted: mek });
        }

        if (sub === 'sell') {
            const carId = (args[1] || '').toLowerCase();
            const idx   = (p.cars || []).findIndex(x => x.id === carId);
            if (idx === -1) return conn.sendMessage(from, { text: `You don't own that car.` }, { quoted: mek });
            const car    = CAR_CATALOGUE[carId];
            const resale = Math.floor(livePrice({ id: carId, price: car.price }) * 0.60);
            p.cars.splice(idx, 1);
            if (p.activeCar === carId) p.activeCar = p.cars[0]?.id || null;
            p.money += resale;
            await p.save();
            return conn.sendMessage(from, { text: `🚗 Sold *${car.name}* for ${fmtMoney(resale)} (60% resale).` }, { quoted: mek });
        }

        // mycar — default
        if (!p.cars?.length) return conn.sendMessage(from, { text: `You don't own any cars.\nBrowse: *car list*` }, { quoted: mek });
        const lines = [`🚗 *YOUR GARAGE*`, ``];
        for (const c of p.cars) {
            const isActive = c.id === p.activeCar;
            const cat = CAR_CATALOGUE[c.id];
            lines.push(`${cat?.icon || '🚗'} *${c.name}*${isActive ? ' ⭐ SELECTED' : ''}\n   Speed: ${c.speed} | Handling: ${c.handling} | Tune: ${c.tunePoints || 0}/10 | Wins: ${c.wins || 0}`);
        }
        lines.push(``, `Switch car: *car select <id>* | Tune: *car tune <id>*`);
        return conn.sendMessage(from, { text: lines.join('\n') }, { quoted: mek });
    } catch(e) { console.error('car error', e); }
});

