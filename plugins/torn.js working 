async function tryLevelUp(playerDoc) {
    let leveled = false;
    while (playerDoc.exp >= xpToLevel(playerDoc.level)) {
        playerDoc.exp -= xpToLevel(playerDoc.level);
        playerDoc.level += 1;
        playerDoc.maxHealth += 10;
        playerDoc.health = playerDoc.maxHealth;
