cmd({ pattern: 'factionrecruit', desc: 'factionrecruit open|close|apply|accept|kick', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
    try {
        const pId = await getPlayerId(conn, sender);
        const p   = await getOrCreatePlayer(pId);
        const sub = (args[0] || 'status').toLowerCase();

        if (!p.faction && sub !== 'apply') return conn.sendMessage(from, { text: `You're not in a faction.` }, { quoted: mek });
        const f = p.faction ? await Faction.findById(p.faction).exec() : null;

        if (sub === 'open') {
            if (f?.owner !== pId) return conn.sendMessage(from, { text: `Only the faction owner can change recruiting status.` }, { quoted: mek });
            f.recruiting = true; await f.save();
            return conn.sendMessage(from, { text: `✅ *${f.name}* is now open for applications!\nPlayers apply with: *factionrecruit apply ${f.name}*` }, { quoted: mek });
        }
        if (sub === 'close') {
            if (f?.owner !== pId) return conn.sendMessage(from, { text: `Only the faction owner can change recruiting status.` }, { quoted: mek });
            f.recruiting = false; await f.save();
            return conn.sendMessage(from, { text: `🔒 *${f.name}* is now closed for applications.` }, { quoted: mek });
        }
        if (sub === 'apply') {
            const facName = args.slice(1).join(' ').trim();
            const target  = await Faction.findOne({ name: new RegExp(`^${facName.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')}$`,'i') }).exec();
            if (!target) return conn.sendMessage(from, { text: `Faction "${facName}" not found.` }, { quoted: mek });
            if (!target.recruiting) return conn.sendMessage(from, { text: `*${target.name}* is not currently recruiting.` }, { quoted: mek });
            if (p.faction) return conn.sendMessage(from, { text: `Leave your current faction first.` }, { quoted: mek });
            if (target.pendingApplicants.includes(pId)) return conn.sendMessage(from, { text: `You already applied to ${target.name}.` }, { quoted: mek });
            target.pendingApplicants.push(pId);
            await target.save();
            return conn.sendMessage(from, { text: `📋 Application sent to *${target.name}*. Faction owner will review it.` }, { quoted: mek });
        }
        if (sub === 'accept') {
            if (f?.owner !== pId && !f?.officers?.includes(pId)) return conn.sendMessage(from, { text: `Only officers can accept applicants.` }, { quoted: mek });
            const targetId = await getTargetId(conn, mek, args, 1);
            if (!targetId || !f.pendingApplicants.includes(targetId)) return conn.sendMessage(from, { text: `No pending application from that player.` }, { quoted: mek });
            if (f.members.length >= (f.maxMembers || 10)) return conn.sendMessage(from, { text: `Faction is full (${f.members.length}/${f.maxMembers}).` }, { quoted: mek });
            f.pendingApplicants = f.pendingApplicants.filter(x => x !== targetId);
            f.members.push(targetId);
            const recruit = await getOrCreatePlayer(targetId);
            recruit.faction = f._id;
            await recruit.save(); await f.save();
            await addFactionXP(f, 50); await f.save();
            logGlobal('🏢', `*${recruit.username || targetId}* joined *${f.name}*!`);
            return conn.sendMessage(from, { text: `✅ @${targetId} accepted into *${f.name}*!`, mentions: [toJid(targetId)] }, { quoted: mek });
        }
        if (sub === 'applicants') {
            if (!f || (f.owner !== pId && !f.officers?.includes(pId))) return conn.sendMessage(from, { text: `Officers only.` }, { quoted: mek });
            if (!f.pendingApplicants.length) return conn.sendMessage(from, { text: `No pending applications.` }, { quoted: mek });
            return conn.sendMessage(from, { text: `📋 *Pending Applications:*\n${f.pendingApplicants.map(x=>`@${x}`).join('\n')}\n\nAccept: *factionrecruit accept @player*`, mentions: f.pendingApplicants.map(toJid) }, { quoted: mek });
        }
        return conn.sendMessage(from, { text: `Usage: factionrecruit open|close|apply <faction>|accept @player|applicants` }, { quoted: mek });
    } catch(e) { console.error('factionrecruit error', e); }
});

