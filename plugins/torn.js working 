                { name: 'Casino Heist',        minLvl:2, reward:[1000000,4000000], energy:30, minMembers:3, failChance:0.35 },
                { name: 'Bank Vault',          minLvl:4, reward:[5000000,20000000],energy:40, minMembers:4, failChance:0.40 },
                { name: 'Federal Reserve',     minLvl:6, reward:[20000000,80000000],energy:50, minMembers:5, failChance:0.50 },
                { name: 'Crypto Exchange Hack',minLvl:8, reward:[50000000,200000000],energy:60,minMembers:4,failChance:0.55 },
