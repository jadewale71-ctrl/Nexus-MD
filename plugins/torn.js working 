// PRESIDENT / CITY ROLES SYSTEM
// Elections every 7 days. Anyone can run. All players vote. Winner gets perks.
// Perks: tax rate discount city-wide, can grant pardons, set city event
// ─────────────────────────────────────────────────────────────────────────────
if (!global.wwPresident)  global.wwPresident  = null;  // {playerId, name, city, since, termEndsAt}
if (!global.wwVicePresident) global.wwVicePresident = null;

async function getActiveElection() {
    return Election.findOne({ status: 'open', endsAt: { $gt: Date.now() } }).exec();
}

// Start election automatically every 7 days
setInterval(async () => {
    try {
        const existing = await getActiveElection();
        if (existing) return;
        const lastClosed = await Election.findOne({ status: 'closed' }).sort({ endsAt: -1 }).exec();
        if (lastClosed && Date.now() - lastClosed.endsAt < 7 * 24 * 60 * 60 * 1000) return;
        // Start new election
        const elId = `EL${Date.now().toString(36).toUpperCase()}`;
        const el   = new Election({
            electionId: elId,
            city:       'Weirdos World',
            endsAt:     Date.now() + 48 * 60 * 60 * 1000, // 48hr voting window
        });
        await el.save();
        logGlobal('🗳️', `*ELECTION OPEN!* A new presidential election has started. Run for president with *president run <campaign>*. Voting closes in 48 hours.`);
    } catch(e) {}
}, 6 * 60 * 60 * 1000); // check every 6 hrs

// Auto-close election when time runs out
setInterval(async () => {
    try {
        const el = await Election.findOne({ status: 'open', endsAt: { $lte: Date.now() } }).exec();
        if (!el) return;
        if (!el.candidates.length) { el.status = 'closed'; await el.save(); return; }
        // Tally
        const tallied = el.candidates.map(c => ({ ...c, total: Object.values(el.votes || {}).filter(v => v === c.playerId).length }))
            .sort((a,b) => b.total - a.total);
        const winner = tallied[0];
        el.winner = winner.playerId;
        el.status = 'closed';
        await el.save();
        global.wwPresident = { playerId: winner.playerId, name: winner.name, city: el.city, since: Date.now(), termEndsAt: Date.now() + 7*24*60*60*1000 };
        global.wwVicePresident = tallied[1] ? { playerId: tallied[1].playerId, name: tallied[1].name } : null;
        logGlobal('🏛️', `*${winner.name}* has won the election with ${winner.total} votes! They are now *President of Weirdos World*! Perks: can pardon players, set city events, and all citizens get a 2% tax discount.`);
    } catch(e) {}
}, 10 * 60 * 1000); // check every 10 min

