        if (sub === 'pardon') {
            if (!global.wwPresident || global.wwPresident.playerId !== pId) return conn.sendMessage(from, { text: `Only the current President can issue pardons.` }, { quoted: mek });
            const targetId = await getTargetId(conn, mek, args, 1);
            if (!targetId) return conn.sendMessage(from, { text: `Usage: president pardon @player` }, { quoted: mek });
            const target = await getOrCreatePlayer(targetId);
            if (!isHospitalized(target)) return conn.sendMessage(from, { text: `@${targetId} is not jailed/hospitalized.` }, { quoted: mek });
            target.jailedUntil = 0;
            target.health      = Math.max(20, target.health);
            target.crimeLevel  = Math.max(0, (target.crimeLevel || 0) - 20);
            await target.save();
            logGlobal('🏛️', `*President ${p.username || pId}* has pardoned *${target.username || targetId}*!`);
            return conn.sendMessage(from, { text: `🏛️ *PRESIDENTIAL PARDON ISSUED*\n@${targetId} has been freed by executive order.`, mentions: [toJid(targetId)] }, { quoted: mek });
        }

        if (sub === 'setevent') {
            if (!global.wwPresident || global.wwPresident.playerId !== pId) return conn.sendMessage(from, { text: `Only the current President can set city events.` }, { quoted: mek });
