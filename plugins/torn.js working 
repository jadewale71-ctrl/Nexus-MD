            if (el.votes?.[pId]) return conn.sendMessage(from, { text: `You already voted in this election.` }, { quoted: mek });
            const targetId = await getTargetId(conn, mek, args, 1);
            if (!targetId) return conn.sendMessage(from, { text: `Usage: president vote @candidate` }, { quoted: mek });
