if (!global.highLowCard) global.highLowCard = Math.floor(Math.random() * 13) + 1;
const CARD_FACES = { 1:'Ace', 11:'Jack', 12:'Queen', 13:'King' };
function cardName(n) { return CARD_FACES[n] || String(n); }
function cardEmoji(n) {
    if (n <= 3) return '🃏';
    if (n <= 6) return '♦️';
    if (n <= 9) return '♣️';
    if (n <= 12) return '♠️';
    return '👑';
}

