            const lvl = f.level || 1;
            const HEIST_TIERS = [
                { name: 'Warehouse Robbery',  minLvl:1, reward:[200000,800000],   energy:20, minMembers:2 },
                { name: 'Casino Heist',        minLvl:2, reward:[1000000,4000000], energy:30, minMembers:3 },
