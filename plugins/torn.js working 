// CHILDREN SYSTEM
// Married players can have children. Children grow, need feeding, schooling,
// and playing. They develop traits. Neglect has consequences.
// =============================================================================
const CHILD_NAMES_M = ['Liam','Noah','James','Oliver','Elijah','Mason','Ethan','Aiden','Kai','Zion','Jaxon','Leo'];
const CHILD_NAMES_F = ['Olivia','Emma','Ava','Sophia','Isabella','Mia','Luna','Zara','Nora','Lily','Chloe','Aria'];
const CHILD_TRAITS  = ['Brave','Smart','Creative','Athletic','Charming','Rebellious','Curious','Kind','Stubborn','Funny'];
const SCHOOL_STAGES = ['Infant','Primary School','Secondary School','University Graduate'];
const SCHOOL_COST   = [0, 5000, 20000, 100000]; // per session
const SCHOOL_DURATION_MS = [0, 2*60*60*1000, 4*60*60*1000, 8*60*60*1000]; // session duration

function getChildAge(child) {
    // 1 game-day = 1 real hour
    return Math.floor((Date.now() - child.bornAt) / 3600000);
}

cmd({ pattern: 'tryforachild', desc: 'Try to conceive with your spouse (must be married)', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from }) => {
    try {
        const pId = await getPlayerId(conn, sender);
        const p   = await getOrCreatePlayer(pId);
        if (!p.spouse || !p.marriageRole) return conn.sendMessage(from, { text: `You need to be married first! Use *marry @player*` }, { quoted: mek });
        if (isHospitalized(p)) return conn.sendMessage(from, { text: `Not from a hospital bed.` }, { quoted: mek });

        const CD = 6 * 60 * 60 * 1000; // 6 hour cooldown
        if (now() - (p.lastIntimacy || 0) < CD) return conn.sendMessage(from, { text: `⏳ Not yet. Try again in ${shortTime(CD - (now() - (p.lastIntimacy||0)))}.` }, { quoted: mek });

        p.lastIntimacy = now();
        const conceived = Math.random() < 0.35; // 35% chance per attempt

        if (!conceived) {
            await p.save();
            return conn.sendMessage(from, { text: [`💑 You and your spouse spent some quality time together.`, ``, `No baby this time — try again later!`, `_35% chance per attempt. Cooldown: 6 hours._`].join('\n') }, { quoted: mek });
        }

        // Baby born!
        const gender  = Math.random() < 0.5 ? 'M' : 'F';
        const names   = gender === 'M' ? CHILD_NAMES_M : CHILD_NAMES_F;
        const babyName = names[Math.floor(Math.random() * names.length)];
        const trait1  = CHILD_TRAITS[Math.floor(Math.random() * CHILD_TRAITS.length)];

        const baby = {
            name:        babyName,
            bornAt:      now(),
            age:         0,
            health:      100,
            hunger:      100,
            happiness:   100,
            schoolLevel: 0,
            lastFed:     now(),
            lastSchool:  0,
            lastPlay:    now(),
            traits:      [trait1],
        };
        p.children = p.children || [];
        p.children.push(baby);

        // Also add to spouse's record
        const spouse = await getOrCreatePlayer(p.spouse);
        spouse.children = spouse.children || [];
        spouse.children.push(baby);
        await spouse.save();

        await p.save();
        logGlobal('👶', `*${p.username || pId}* and their spouse just had a baby! Welcome *${babyName}* to Weirdos World!`);
        return conn.sendMessage(from, { text: [
            `👶 *A BABY IS BORN!*`, ``,
            `Name: *${babyName}*`,
            `Gender: ${gender === 'M' ? '👦 Boy' : '👧 Girl'}`,
            `Trait: ✨ *${trait1}*`, ``,
            `Take care of ${babyName} with:`,
            `• *children* — view all your children`,
            `• *feedchild <name>* — feed them ($500)`,
            `• *playwithchild <name>* — keep them happy`,
            `• *schoolchild <name>* — send to school`,
        ].join('\n') }, { quoted: mek });
    } catch(e) { console.error('tryforachild error', e); }
});

cmd({ pattern: 'children', desc: 'View your children and their status', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from }) => {
    try {
        const p = await getOrCreatePlayer(await getPlayerId(conn, sender));
        if (!p.children?.length) return conn.sendMessage(from, { text: [`👶 You have no children.`, ``, `Have a child with your spouse: *tryforachild*`].join('\n') }, { quoted: mek });

        const lines = [`👶 *YOUR CHILDREN*`, ``];
        for (const c of p.children) {
            const ageHrs  = getChildAge(c);
            const ageDays = Math.floor(ageHrs / 24);
            const hungry  = (now() - (c.lastFed || 0)) > 4 * 60 * 60 * 1000;
            const neglected = c.happiness < 30;
            const stage   = SCHOOL_STAGES[c.schoolLevel || 0];
            lines.push(`${c.schoolLevel >= 3 ? '🎓' : '👶'} *${c.name}* — Age: ${ageDays} days old`);
            lines.push(`   ❤️ Health: ${c.health}/100 | 🍽️ Hunger: ${c.hunger}/100 | 😊 Happy: ${c.happiness}/100`);
            lines.push(`   🎒 Stage: ${stage} | ✨ Traits: ${c.traits?.join(', ') || 'None yet'}`);
            if (hungry) lines.push(`   ⚠️ *${c.name} is hungry! Feed them: feedchild ${c.name}*`);
            if (neglected) lines.push(`   😢 *${c.name} is unhappy. Play with them: playwithchild ${c.name}*`);
        }
        lines.push(``, `Commands: feedchild | playwithchild | schoolchild | namechild`);
        return conn.sendMessage(from, { text: lines.join('\n') }, { quoted: mek });
    } catch(e) { console.error('children error', e); }
});

cmd({ pattern: 'feedchild', desc: 'Feed one of your children ($500)', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
    try {
        const p    = await getOrCreatePlayer(await getPlayerId(conn, sender));
        const name = args.join(' ').trim();
        if (!name) return conn.sendMessage(from, { text: `Usage: feedchild <name>` }, { quoted: mek });
        const child = (p.children || []).find(c => c.name.toLowerCase() === name.toLowerCase());
        if (!child) return conn.sendMessage(from, { text: `No child named "${name}". Use *children* to see your kids.` }, { quoted: mek });

        const COST = 500;
        if (p.money < COST) return conn.sendMessage(from, { text: `Feeding costs $${COST}. You're broke — your child goes hungry.` }, { quoted: mek });

        p.money -= COST;
        child.hunger    = Math.min(100, (child.hunger || 0) + 40);
        child.health    = Math.min(100, (child.health || 0) + 5);
        child.happiness = Math.min(100, (child.happiness || 0) + 5);
        child.lastFed   = now();
        p.markModified('children');
        await p.save();
        return conn.sendMessage(from, { text: [`🍽️ You fed *${child.name}*! (-$${COST})`, ``, `❤️ Health: ${child.health}/100 | 🍽️ Hunger: ${child.hunger}/100 | 😊 Happy: ${child.happiness}/100`].join('\n') }, { quoted: mek });
    } catch(e) { console.error('feedchild error', e); }
});

cmd({ pattern: 'playwithchild', desc: 'Spend time with your child (raises happiness)', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
    try {
        const p    = await getOrCreatePlayer(await getPlayerId(conn, sender));
        const name = args.join(' ').trim();
        if (!name) return conn.sendMessage(from, { text: `Usage: playwithchild <name>` }, { quoted: mek });
        const child = (p.children || []).find(c => c.name.toLowerCase() === name.toLowerCase());
        if (!child) return conn.sendMessage(from, { text: `No child named "${name}".` }, { quoted: mek });

        const CD = 2 * 60 * 60 * 1000;
        if (now() - (child.lastPlay || 0) < CD) return conn.sendMessage(from, { text: `⏳ ${child.name} needs a break. Come back in ${shortTime(CD - (now() - (child.lastPlay||0)))}.` }, { quoted: mek });

        child.happiness = Math.min(100, (child.happiness || 0) + 25);
        child.health    = Math.min(100, (child.health || 0) + 5);
        child.lastPlay  = now();

        // Chance to develop a new trait
        let traitMsg = '';
        if (Math.random() < 0.10 && (child.traits||[]).length < 4) {
            const newTrait = CHILD_TRAITS.find(t => !(child.traits||[]).includes(t));
            if (newTrait) { child.traits = [...(child.traits||[]), newTrait]; traitMsg = `\n✨ *${child.name} developed the trait: ${newTrait}!*`; }
        }
        p.markModified('children');
        await p.save();
        return conn.sendMessage(from, { text: [`🎮 You played with *${child.name}*!`, ``, `😊 Happiness: ${child.happiness}/100 | ❤️ Health: ${child.health}/100${traitMsg}`].join('\n') }, { quoted: mek });
    } catch(e) { console.error('playwithchild error', e); }
});

cmd({ pattern: 'schoolchild', desc: 'Send your child to school to advance their education', category: 'rpg', filename: __filename }, async (conn, mek, m, { sender, from, args }) => {
    try {
        const p    = await getOrCreatePlayer(await getPlayerId(conn, sender));
        const name = args.join(' ').trim();
        if (!name) return conn.sendMessage(from, { text: `Usage: schoolchild <name>` }, { quoted: mek });
        const child = (p.children || []).find(c => c.name.toLowerCase() === name.toLowerCase());
        if (!child) return conn.sendMessage(from, { text: `No child named "${name}".` }, { quoted: mek });

        const ageHrs = getChildAge(child);
        if (ageHrs < 24 && child.schoolLevel === 0) return conn.sendMessage(from, { text: `${child.name} is too young for school! Wait until they're at least 1 day old.` }, { quoted: mek });
        if ((child.schoolLevel || 0) >= 3) return conn.sendMessage(from, { text: `🎓 *${child.name}* is already a University Graduate!` }, { quoted: mek });

        const nextLevel = (child.schoolLevel || 0) + 1;
        const cost      = SCHOOL_COST[nextLevel];
        const duration  = SCHOOL_DURATION_MS[nextLevel];

        const lastSchool = child.lastSchool || 0;
        if (now() - lastSchool < duration) return conn.sendMessage(from, { text: `⏳ ${child.name} is still in school. Finishes in ${shortTime(duration - (now() - lastSchool))}.` }, { quoted: mek });

        if (p.money < cost) return conn.sendMessage(from, { text: `School fees: ${fmtMoney(cost)}. You don't have enough.` }, { quoted: mek });

        p.money -= cost;
        child.schoolLevel = nextLevel;
        child.lastSchool  = now();
        child.happiness   = Math.min(100, (child.happiness || 0) + 10);

        // Graduate gets a trait
        if (nextLevel === 3) {
            const grad = ['Smart','Ambitious','Disciplined'].find(t => !(child.traits||[]).includes(t));
            if (grad) child.traits = [...(child.traits||[]), grad];
        }

        p.markModified('children');
        await p.save();

        const stages = ['','Primary School','Secondary School','University'];
        logGlobal('🎓', `*${child.name}* (${p.username || pId}'s child) just started *${stages[nextLevel]}*!`);
        return conn.sendMessage(from, { text: [
            `🎒 *${child.name} enrolled in ${stages[nextLevel]}!*`, ``,
            `Cost: ${fmtMoney(cost)}`,
            `Duration: ${shortTime(duration)}`,
            `Stage: *${SCHOOL_STAGES[nextLevel]}*`,
            nextLevel === 3 ? `🎓 When they graduate they'll be University educated — the highest level!` : ``
        ].filter(Boolean).join('\n') }, { quoted: mek });
    } catch(e) { console.error('schoolchild error', e); }
});

