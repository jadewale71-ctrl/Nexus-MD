            if (success) {
                const gross  = Math.floor(heist.reward[0] + Math.random() * (heist.reward[1] - heist.reward[0]));
                const share  = Math.floor(gross / available.length);
                f.funds     += Math.floor(gross * 0.20); // 20% to faction
                const memberCut = Math.floor(gross * 0.80 / available.length);
                for (const mb of available) {
                    mb.energy -= heist.energy;
                    mb.money  += memberCut;
                    addTaxableIncome(mb, memberCut);
                    await mb.save();
