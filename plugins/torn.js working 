                await addFactionXP(f, 200); await f.save();
                logGlobal('🦹', `*${f.name}* pulled off a *${heist.name}* and netted ${fmtMoney(gross)}!`);
                return conn.sendMessage(from, { text: [`🦹 *${heist.name.toUpperCase()} — SUCCESS!*`,``,`💰 Total take: *${fmtMoney(gross)}*`,`🏢 Faction cut (20%): ${fmtMoney(Math.floor(gross*0.2))}`,`👥 Each member gets: *${fmtMoney(memberCut)}*`,`⭐ +200 Faction XP`].join('\n') }, { quoted: mek });
            } else {
                // Failed — all members jailed
                for (const mb of available) {
                    mb.energy = Math.max(0, mb.energy - heist.energy);
                    mb.jailedUntil = now() + 30*60*1000;
                    mb.crimeLevel  = Math.min(100, (mb.crimeLevel||0) + 25);
                    await mb.save();
