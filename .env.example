# NEXUS-MD — Copy this to .env and fill in your values

SESSION_ID=NEXUS-MD=your_session_id_here
OWNER_NUMBER=your_phone_number_here
OWNER_NAME=YourName
BOT_NAME=NEXUS-MD
PREFIX=:
MODE=public
MONGO_URI=
DATABASE_URL=./data/nexus.db
SELF_URL=https://your-app.onrender.com
STICKER_PACK=NEXUS-MD
STICKER_AUTHOR=nexus
TIMEZONE=Africa/Johannesburg
HEROKU_APP_NAME=
HEROKU_API_KEY=

# HuggingFace Spaces uses port 7860 automatically via the PORT env var
# PORT=7860
